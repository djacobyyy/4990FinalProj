   "source": [
    "import cv2\n",
    "import time\n",
    "import numpy as np\n",
    "import PIL.Image\n",
    "from IPython.display import display, clear_output\n",
    "\n",
    "import mediapipe as mp\n",
    "from mediapipe.tasks import python\n",
    "from mediapipe.tasks.python import vision\n",
    "\n",
    "# -----------------------------\n",
    "# Virtual piano setup\n",
    "# -----------------------------\n",
    "WHITE_KEYS = [\"C\", \"D\", \"E\", \"F\", \"G\", \"A\", \"B\"]\n",
    "NUM_KEYS = len(WHITE_KEYS)\n",
    "\n",
    "FRAME_WIDTH = 800\n",
    "FRAME_HEIGHT = 500\n",
    "\n",
    "PIANO_Y = 300\n",
    "PIANO_HEIGHT = 150\n",
    "KEY_WIDTH = FRAME_WIDTH // NUM_KEYS\n",
    "\n",
    "PRESS_COOLDOWN = 0.3\n",
    "\n",
    "\n",
    "# MediaPipe Tasks setup\n",
    "\n",
    "base_options = python.BaseOptions(model_asset_path=\"hand_landmarker.task\")\n",
    "options = vision.HandLandmarkerOptions(\n",
    "    base_options=base_options,\n",
    "    num_hands=1\n",
    ")\n",
    "detector = vision.HandLandmarker.create_from_options(options)\n",
    "\n",
    "\n",
    "# Helper functions\n",
    "\n",
    "def draw_piano(frame, active_key=None):\n",
    "    for i in range(NUM_KEYS):\n",
    "        x1 = i * KEY_WIDTH\n",
    "        y1 = PIANO_Y\n",
    "        x2 = x1 + KEY_WIDTH\n",
    "        y2 = PIANO_Y + PIANO_HEIGHT\n",
    "\n",
    "        if i == active_key:\n",
    "            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), -1)\n",
    "        else:\n",
    "            cv2.rectangle(frame, (x1, y1), (x2, y2), (255, 255, 255), -1)\n",
    "\n",
    "        cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 0, 0), 2)\n",
    "        cv2.putText(frame, WHITE_KEYS[i], (x1 + 20, y2 - 10),\n",
    "                    cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 0, 0), 2)\n",
    "\n",
    "def get_key(x, y):\n",
    "    if y < PIANO_Y or y > PIANO_Y + PIANO_HEIGHT:\n",
    "        return None\n",
    "    key_index = x // KEY_WIDTH\n",
    "    if 0 <= key_index < NUM_KEYS:\n",
    "        return key_index\n",
    "    return None\n",
    "\n",
    "def draw_hand_points(frame, landmarks):\n",
    "    # Draw all landmarks\n",
    "    for lm in landmarks:\n",
    "        x = int(lm.x * FRAME_WIDTH)\n",
    "        y = int(lm.y * FRAME_HEIGHT)\n",
    "        cv2.circle(frame, (x, y), 3, (255, 0, 0), -1)\n",
    "\n",
    "    # Index fingertip = landmark 8\n",
    "    tip = landmarks[8]\n",
    "    fx = int(tip.x * FRAME_WIDTH)\n",
    "    fy = int(tip.y * FRAME_HEIGHT)\n",
    "    cv2.circle(frame, (fx, fy), 8, (0, 0, 255), -1)\n",
    "    return fx, fy\n",
    "\n",
    "\n",
    "# Webcam loop for Jupyter\n",
    "cap = cv2.VideoCapture(0)\n",
    "\n",
    "last_key = None\n",
    "last_time = 0\n",
    "\n",
    "try:\n",
    "    while True:\n",
    "        ret, frame = cap.read()\n",
    "        if not ret:\n",
    "            print(\"Could not access webcam.\")\n",
    "            break\n",
    "\n",
    "        frame = cv2.flip(frame, 1)\n",
    "        frame = cv2.resize(frame, (FRAME_WIDTH, FRAME_HEIGHT))\n",
    "\n",
    "        # MediaPipe expects RGB\n",
    "        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n",
    "        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)\n",
    "\n",
    "        result = detector.detect(mp_image)\n",
    "\n",
    "        active_key = None\n",
    "\n",
    "        if result.hand_landmarks:\n",
    "            hand_landmarks = result.hand_landmarks[0]\n",
    "            fx, fy = draw_hand_points(frame, hand_landmarks)\n",
    "\n",
    "            active_key = get_key(fx, fy)\n",
    "\n",
    "            current_time = time.time()\n",
    "            if active_key is not None:\n",
    "                if active_key != last_key or (current_time - last_time > PRESS_COOLDOWN):\n",
    "                    print(f\"Pressed: {WHITE_KEYS[active_key]}\")\n",
    "                    last_key = active_key\n",
    "                    last_time = current_time\n",
    "\n",
    "            cv2.putText(frame, f\"Finger: ({fx}, {fy})\", (20, 40),\n",
    "                        cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 0, 0), 2)\n",
    "\n",
    "        draw_piano(frame, active_key)\n",
    "\n",
    "        if active_key is not None:\n",
    "            cv2.putText(frame, f\"Pressed: {WHITE_KEYS[active_key]}\", (20, 85),\n",
    "                        cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 128, 0), 3)\n",
    "        else:\n",
    "            cv2.putText(frame, \"Pressed: None\", (20, 85),\n",
    "                        cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 255), 3)\n",
    "\n",
    "        cv2.putText(frame, \"Virtual Piano Preliminary Demo\", (20, 130),\n",
    "                    cv2.FONT_HERSHEY_SIMPLEX, 0.9, (50, 50, 50), 2)\n",
    "\n",
    "        # Show inline in notebook\n",
    "        frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n",
    "        img = PIL.Image.fromarray(frame_rgb)\n",
    "\n",
    "        clear_output(wait=True)\n",
    "        display(img)\n",
    "\n",
    "except KeyboardInterrupt:\n",
    "    print(\"Stopped.\")\n",
    "\n",
    "finally:\n",
    "    cap.release()"
   ]
  },
